# exoclaw — no API key needed, subscription auth only.
#
# After `docker compose up`, authenticate each instance:
#   docker exec -it greg claude login
#   docker exec -it linda claude login
#
# Channel tokens go in the instance JSON or as env overrides below.

# Optional per-instance channel tokens (override JSON config)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
# DISCORD_BOT_TOKEN=...
# TELEGRAM_BOT_TOKEN=...

# Shared gateway API token — one value for the whole fleet.
# Every container uses this as its own Bearer token (GET/PUT /api/*, POST /webhook)
# AND as the peer token when calling another container's /mcp endpoint.
# Generate with: openssl rand -hex 32
# EXOCLAW_API_TOKEN=

# Tailscale Funnel — configure via the dashboard Tunnel section.
# Install first: docker exec -it <name> sudo /app/scripts/install-tailscale.sh
# Env overrides (optional — dashboard fields take precedence):
# TS_AUTHKEY=tskey-auth-...
# TS_HOSTNAME=exoclaw
